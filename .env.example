# GitHub Personal Access Token (5,000 req/hr vs 60 unauthenticated)
GITHUB_TOKEN=ghp_your_token_here

# Redis (leave empty to use in-memory cache)
REDIS_URL=

# NVIDIA NIM API Key (optional - for AI-generated improvement suggestions)
# Get free key at https://build.nvidia.com/
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# Server
PORT=3000
PUBLIC_DOMAIN=https://your-deployed-url.com

# Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Cache
CACHE_TTL_SECONDS=21600

# Scoring
SCORE_THRESHOLD=14
